# ============================================
# CREDENCIALES DEL SISTEMA
# ============================================
#
# INSTRUCCIONES:
# 1. Copia este archivo como .env → comando: cp .env.example .env
# 2. Llena cada valor con tus datos reales
# 3. NUNCA subas el archivo .env a git (ya esta en .gitignore)
#
# Si usas /setup, Claude te guia para conseguir cada una.
# ============================================

# --- RETELL AI (Agente de voz) ---
# Donde conseguirla: https://www.retellai.com/dashboard → API Keys
RETELL_API_KEY=

# --- TWILIO (Telefonia) ---
# Donde conseguirlas: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=              # Formato: +1XXXXXXXXXX

# --- NOTION (CRM / Base de datos) ---
# Donde conseguirlas: https://www.notion.so/my-integrations → Create new integration
# El Parent Page ID es el ID de la pagina donde se crearan las bases de datos
# (es la parte larga de la URL cuando abres una pagina en Notion)
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# --- CAL.COM (Agenda de citas) ---
# Donde conseguirlas: https://app.cal.com/settings/developer/api-keys
# El Event Type ID es el numero del tipo de evento (ej: consulta, visita)
# Lo encuentras en: Cal.com → Event Types → click en el evento → el numero en la URL
CAL_API_KEY=
CAL_EVENT_TYPE_ID=

# --- ANTHROPIC / CLAUDE (Analisis post-llamada) ---
# Donde conseguirla: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- MODAL (Hosting del backend) ---
# Se configura automaticamente cuando corres: modal token new
# No necesitas poner nada aqui — Modal usa su propio sistema de auth
